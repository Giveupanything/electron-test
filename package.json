{
  "name": "ai-assistant",
  "version": "2.0.0",
  "main": "dist-electron/main/index.js",
  "description": "ai-assistant",
  "author": "JokerMax",
  "license": "MIT",
  "private": true,
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:7777/"
    }
  },
  "type": "module",
  "scripts": {
    "dev:origin": "vite",
    "dev": "cross-env VITE_APP_BUILD_ENV=desktop vite",
    "dev:pc": "cross-env VITE_APP_BUILD_ENV=pc && vite",
    "build:pc": "cross-env VITE_APP_BUILD_ENV=pc && vite build",
    "build": "tsc && vite build && electron-builder",
    "build-32": "tsc && vite build && electron-builder --win --ia32",
    "build-mac": "tsc && vite build && electron-builder --mac",
    "clean": "rimraf release dist-electron dist",
    "preview": "vite preview",
    "pretest": "vite build --mode=test",
    "test": "vitest run"
  },
  "dependencies": {
    "docx-preview": "^0.3.5",
    "electron-updater": "^6.3.9",
    "react-scrollbars-custom": "^4.1.1"
  },
  "devDependencies": {
    "@ant-design/icons": "^5.6.1",
    "@emoji-mart/data": "^1.2.1",
    "@floating-ui/react": "^0.27.5",
    "@headlessui/react": "^2.2.0",
    "@heroicons/react": "^2.2.0",
    "@iconify-icon/react": "^2.1.0",
    "@monaco-editor/react": "^4.6.0",
    "@playwright/test": "^1.48.2",
    "@remixicon/react": "4.5.0",
    "@tailwindcss/typography": "^0.5.16",
    "@turbotools/react": "^1.0.1",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.11.30",
    "@types/nprogress": "^0.2.3",
    "@types/qs": "^6.9.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-router-dom": "^5.3.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "ahooks": "^3.8.0",
    "antd": "^5.24.4",
    "autoprefixer": "^10.4.20",
    "axios": "^1.6.8",
    "class-variance-authority": "^0.7.1",
    "classnames": "^2.5.1",
    "copy-to-clipboard": "3.3.3",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^24.13.3",
    "emoji-mart": "^5.6.0",
    "eslint": "^8.57.0",
    "eslint-plugin-prettier": "5.2.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "immer": "9.0.19",
    "js-cookie": "^3.0.5",
    "katex": "^0.16.21",
    "lodash-es": "^4.17.21",
    "mime": "^4.0.6",
    "nprogress": "^0.2.0",
    "postcss": "^8.4.49",
    "postcss-import": "^16.1.0",
    "qs": "^6.12.0",
    "rc-textarea": "^1.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hotkeys-hook": "^4.6.1",
    "react-i18next": "^15.1.0",
    "react-markdown": "8.0.6",
