    "react-tooltip": "5.8.3",
    "reactflow": "^11.11.3",
    "rehype-katex": "6.0.2",
    "remark-breaks": "3.0.2",
    "remark-gfm": "3.0.1",
    "remark-math": "5.1.1",
    "rimraf": "^6.0.1",
    "sass": "^1.80.3",
    "swr": "^2.3.3",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^3.4.15",
    "turboutils": "^1.0.1",
    "typescript": "^5.4.2",
    "use-context-selector": "^2.0.0",
    "uuid": "^11.1.0",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-svgr": "^4.2.0",
    "vitest": "^2.1.5",
